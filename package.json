{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "concurrently \"pnpm run dev:db\" \"nuxt dev\"",
    "dev:db": "turso dev --db-file local.db",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@nuxt/eslint": "1.3.0",
    "@nuxt/icon": "1.15.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@tailwindcss/vite": "^4.1.13",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^3.17.1",
    "tailwindcss": "^4.1.13",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@iconify-json/tabler": "^1.2.23",
    "concurrently": "^9.2.1",
    "daisyui": "^5.1.25",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.26.0",
    "eslint-plugin-format": "^1.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "zod": "^4.2.1"
  },
  "lint-staged": {
    "*": "pnpm lint --no-warn-ignored"
  }
}
